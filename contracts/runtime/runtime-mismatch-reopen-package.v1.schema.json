{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/contracts/runtime/runtime-mismatch-reopen-package.v1.schema.json",
  "title": "EV4 Runtime Mismatch Reopen Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "package_id",
    "consumer_stage",
    "prior_decision_lineage",
    "runtime_observation",
    "evidence_references",
    "reopen_reason",
    "requested_action",
    "authority_boundary",
    "boundary_claims"
  ],
  "properties": {
    "schema": {
      "const": "runtime-mismatch-reopen-package.v1"
    },
    "package_id": {
      "type": "string",
      "pattern": "^RMR-[A-Z0-9][A-Z0-9._-]{2,63}$"
    },
    "consumer_stage": {
      "type": "string",
      "enum": ["responsive", "builder", "project_gate", "downstream_consumer"]
    },
    "prior_decision_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "decision_schema",
        "repository",
        "commit_sha",
        "artifact_sha256",
        "decision_family",
        "decision_card_ref",
        "selected_option",
        "rejected_options",
        "evidence_refs",
        "evidence_state",
        "consumer_stage"
      ],
      "properties": {
        "decision_id": {"type": "string", "minLength": 1},
        "decision_schema": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "decision_family": {"type": "string", "minLength": 1},
        "decision_card_ref": {"type": "string", "minLength": 1},
        "selected_option": {"const": "blocked_pending_input"},
        "rejected_options": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_state": {"const": "reopen_required"},
        "consumer_stage": {"const": "runtime_evidence_conflict"}
      }
    },
    "runtime_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "environment", "mismatch_code", "expected_state", "observed_state"],
      "properties": {
        "observed_at": {"type": "string", "format": "date-time"},
        "environment": {"type": "string", "minLength": 1},
        "mismatch_code": {"type": "string", "pattern": "^RMR-[A-Z0-9_]{3,64}$"},
        "expected_state": {"type": "string", "minLength": 1},
        "observed_state": {"type": "string", "minLength": 1},
        "diagnostic_detail": {"type": "string", "minLength": 1}
      }
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "uri", "sha256"],
        "properties": {
          "kind": {"type": "string", "enum": ["log", "trace", "fixture", "artifact", "report"]},
          "uri": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "reopen_reason": {
      "type": "string",
      "enum": [
        "runtime_behavior_differs_from_prior_decision",
        "consumer_contract_rejection",
        "lineage_or_artifact_drift",
        "unsupported_runtime_state"
      ]
    },
    "requested_action": {
      "const": "reopen_for_authoritative_review"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["responsive_may_observe", "responsive_may_replace_decision", "authoritative_redecision_required"],
      "properties": {
        "responsive_may_observe": {"const": true},
        "responsive_may_replace_decision": {"const": false},
        "authoritative_redecision_required": {"const": true}
      }
    },
    "boundary_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_evidence_created",
        "issue_8_mutated",
        "pilot_authorized",
        "production_ready",
        "release_ready",
        "live_render_validated",
        "export_json_validated",
        "accessibility_passed",
        "pixel_perfect",
        "responsive_correctness_validated"
      ],
      "properties": {
        "submitted_evidence_created": {"const": false},
        "issue_8_mutated": {"const": false},
        "pilot_authorized": {"const": false},
        "production_ready": {"const": false},
        "release_ready": {"const": false},
        "live_render_validated": {"const": false},
        "export_json_validated": {"const": false},
        "accessibility_passed": {"const": false},
        "pixel_perfect": {"const": false},
        "responsive_correctness_validated": {"const": false}
      }
    }
  }
}
