{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-automation-control-state@1.0.0",
  "title": "EV4 Automation Control State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "project",
    "execution_state_source_of_truth",
    "current_execution_driver",
    "work_package_catalog_path",
    "catalog_authority",
    "catalog_selection_policy",
    "rolling_queue_authority",
    "rolling_queue_execution_status",
    "rolling_queue_path",
    "status_path",
    "latest_material_checkpoint",
    "latest_checkpoint_guard",
    "queue_drift_acknowledged",
    "queue_reconciliation_required_before_queue_driver",
    "arbitrary_task_invention_policy",
    "checkpoint_only_loop_policy",
    "next_action_policy",
    "open_pr_reconciliation_policy",
    "forbidden_next_actions",
    "boundary_claims"
  ],
  "properties": {
    "schema": {"const": "ev4-automation-control-state@1.0.0"},
    "project": {"const": "EV4 Responsive Architect"},
    "execution_state_source_of_truth": {"const": "planning/EV4_AUTOMATION_CONTROL_STATE.json"},
    "current_execution_driver": {"const": "work_package_catalog_guard"},
    "work_package_catalog_path": {"const": "planning/EV4_AUTOMATION_WORK_PACKAGE_CATALOG.json"},
    "catalog_authority": {"const": "approved_material_objective_source"},
    "catalog_selection_policy": {"const": "select_from_catalog_only_one_work_package_or_reviewable_slice"},
    "rolling_queue_authority": {"const": "historical_reconciled_archive"},
    "rolling_queue_execution_status": {"const": "retired_as_execution_driver"},
    "rolling_queue_path": {"const": "planning/EV4_ROLLING_QUEUE.json"},
    "status_path": {"const": "STATUS.md"},
    "latest_material_checkpoint": {"const": "PR #122 RTAQ-0038 rolling queue archive reconciliation"},
    "latest_checkpoint_guard": {"const": "PR #113 RTAQ-0030 bounded foundation checkpoint guard"},
    "queue_drift_acknowledged": {"const": false},
    "queue_reconciliation_required_before_queue_driver": {"const": false},
    "arbitrary_task_invention_policy": {"const": "forbidden_outside_work_package_catalog"},
    "checkpoint_only_loop_policy": {"const": "forbidden_without_material_checkpoint_change"},
    "next_action_policy": {"const": "catalog_material_objective_only"},
    "open_pr_reconciliation_policy": {"const": "reconcile_open_automation_pr_before_new_catalog_selection"},
    "forbidden_next_actions": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {"enum": [
        "create_checkpoint_only_pr_for_every_merge",
        "treat_stale_rolling_queue_as_current_driver",
        "invent_rtaq_task_without_catalog_work_package",
        "invent_micro_task_outside_catalog",
        "create_artificial_reserve_task_to_keep_task_count_high",
        "upgrade_evidence_pilot_readiness_or_release_claims"
      ]}
    },
    "boundary_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_submitted_packet_present",
        "pilot_allowed_to_start",
        "readiness_claims_upgraded",
        "production_ready",
        "release_ready",
        "live_render_validated",
        "export_json_validated",
        "accessibility_passed",
        "pixel_perfect",
        "responsive_correctness_validated"
      ],
      "properties": {
        "real_submitted_packet_present": {"const": false},
        "pilot_allowed_to_start": {"const": false},
        "readiness_claims_upgraded": {"const": false},
        "production_ready": {"const": false},
        "release_ready": {"const": false},
        "live_render_validated": {"const": false},
        "export_json_validated": {"const": false},
        "accessibility_passed": {"const": false},
        "pixel_perfect": {"const": false},
        "responsive_correctness_validated": {"const": false}
      }
    }
  }
}
