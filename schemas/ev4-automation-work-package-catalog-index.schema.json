{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-automation-work-package-catalog-index@1.0.0",
  "title": "EV4 Automation Work Package Catalog Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "project",
    "authority_mode",
    "canonical_catalog_path",
    "package_directory",
    "ordering",
    "package_entries",
    "global_boundaries"
  ],
  "properties": {
    "schema": {
      "const": "ev4-automation-work-package-catalog-index@1.0.0"
    },
    "project": {
      "const": "EV4 Responsive Architect"
    },
    "authority_mode": {
      "enum": [
        "monolith_canonical_modular_shadow",
        "modular_canonical_monolith_generated"
      ]
    },
    "canonical_catalog_path": {
      "const": "planning/EV4_AUTOMATION_WORK_PACKAGE_CATALOG.json"
    },
    "package_directory": {
      "const": "planning/work-packages"
    },
    "ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "direction",
        "duplicate_ids_forbidden",
        "missing_entries_forbidden",
        "unindexed_files_forbidden"
      ],
      "properties": {
        "key": {
          "const": "work_package_id_numeric_suffix"
        },
        "direction": {
          "const": "ascending"
        },
        "duplicate_ids_forbidden": {
          "const": true
        },
        "missing_entries_forbidden": {
          "const": true
        },
        "unindexed_files_forbidden": {
          "const": true
        }
      }
    },
    "package_entries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "schema",
          "content_sha256"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^WP-RESP-[0-9]{3}$"
          },
          "path": {
            "type": "string",
            "pattern": "^planning/work-packages/WP-RESP-[0-9]{3}\\.json$"
          },
          "schema": {
            "const": "ev4-automation-work-package-file@1.0.0"
          },
          "content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "global_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_evidence_created_by_catalog",
        "issue_8_mutation_allowed_by_catalog",
        "real_pilot_execution_allowed_by_catalog",
        "catalog_completion_is_evidence_validation",
        "ci_success_is_responsive_correctness_evidence",
        "production_ready",
        "release_ready",
        "live_render_validated",
        "export_json_validated",
        "accessibility_passed",
        "pixel_perfect",
        "responsive_correctness_validated"
      ],
      "properties": {
        "submitted_evidence_created_by_catalog": {"const": false},
        "issue_8_mutation_allowed_by_catalog": {"const": false},
        "real_pilot_execution_allowed_by_catalog": {"const": false},
        "catalog_completion_is_evidence_validation": {"const": false},
        "ci_success_is_responsive_correctness_evidence": {"const": false},
        "production_ready": {"const": false},
        "release_ready": {"const": false},
        "live_render_validated": {"const": false},
        "export_json_validated": {"const": false},
        "accessibility_passed": {"const": false},
        "pixel_perfect": {"const": false},
        "responsive_correctness_validated": {"const": false}
      }
    }
  }
}
