{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-automation-work-package-catalog@1.0.0",
  "title": "EV4 Automation Work Package Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "project", "catalog_path", "catalog_status", "execution_driver", "rolling_queue_authority", "selection_policy", "execution_policy", "catalog_replenishment_policy", "work_package_requirements", "global_boundaries", "work_packages"],
  "properties": {
    "schema": {"const": "ev4-automation-work-package-catalog@1.0.0"},
    "project": {"const": "EV4 Responsive Architect"},
    "catalog_path": {"const": "planning/EV4_AUTOMATION_WORK_PACKAGE_CATALOG.json"},
    "catalog_status": {"const": "approved_material_objective_source"},
    "execution_driver": {"const": "work_package_catalog_guard"},
    "rolling_queue_authority": {"const": "historical_reconciled_archive"},
    "selection_policy": {"$ref": "#/$defs/true_selection_policy"},
    "execution_policy": {"type": "object", "additionalProperties": false, "required": ["active_work_package_limit", "continue_active_before_starting_new", "reconcile_open_pr_before_new_mutation", "complete_same_objective_in_one_run_when_safe", "open_pr_blocks_new_mutation_pr"], "properties": {"active_work_package_limit": {"const": 1}, "continue_active_before_starting_new": {"const": true}, "reconcile_open_pr_before_new_mutation": {"const": true}, "complete_same_objective_in_one_run_when_safe": {"const": true}, "open_pr_blocks_new_mutation_pr": {"const": true}}},
    "catalog_replenishment_policy": {"$ref": "#/$defs/catalog_replenishment_policy"},
    "work_package_requirements": {"$ref": "#/$defs/work_package_requirements"},
    "global_boundaries": {"$ref": "#/$defs/global_boundaries"},
    "work_packages": {"type": "object", "minProperties": 1, "additionalProperties": false, "propertyNames": {"pattern": "^WP-RESP-[0-9]{3}$"}, "patternProperties": {"^WP-RESP-[0-9]{3}$": {"$ref": "#/$defs/work_package"}}}
  },
  "$defs": {
    "true_selection_policy": {"type": "object", "additionalProperties": false, "required": ["controller_must_select_from_catalog_only", "exactly_one_work_package_or_slice_per_run", "arbitrary_rtaq_task_invention_forbidden", "micro_task_invention_forbidden", "checkpoint_only_loop_forbidden", "artificial_reserve_tasks_forbidden", "guard_only_work_requires_named_work_package_unblock", "open_prs_must_be_reconciled_before_new_selection", "reviewable_pr_slices_required", "split_by_layer_under_same_work_package_id"], "properties": {"controller_must_select_from_catalog_only": {"const": true}, "exactly_one_work_package_or_slice_per_run": {"const": true}, "arbitrary_rtaq_task_invention_forbidden": {"const": true}, "micro_task_invention_forbidden": {"const": true}, "checkpoint_only_loop_forbidden": {"const": true}, "artificial_reserve_tasks_forbidden": {"const": true}, "guard_only_work_requires_named_work_package_unblock": {"const": true}, "open_prs_must_be_reconciled_before_new_selection": {"const": true}, "reviewable_pr_slices_required": {"const": true}, "split_by_layer_under_same_work_package_id": {"const": true}}},
    "catalog_replenishment_policy": {"type": "object", "additionalProperties": false, "required": ["ready_work_package_target", "refresh_when_ready_below", "max_ready_work_packages", "state_driven_refresh", "fixed_ordinal_refresh_forbidden", "artificial_work_packages_forbidden", "checkpoint_only_work_forbidden", "bookkeeping_only_work_forbidden", "catalog_replenishment_must_not_block_active_execution", "catalog_replenishment_must_respect_single_active_pr_policy", "catalog_changes_require_schema_validation", "catalog_changes_require_ci", "catalog_changes_require_reviewable_pr", "state_driven_triggers", "forbidden_refresh_triggers", "when_active_pr_exists", "when_no_active_pr_exists"], "properties": {"ready_work_package_target": {"type": "integer", "minimum": 3, "maximum": 5}, "refresh_when_ready_below": {"type": "integer", "minimum": 2, "maximum": 4}, "max_ready_work_packages": {"const": 5}, "state_driven_refresh": {"const": true}, "fixed_ordinal_refresh_forbidden": {"const": true}, "artificial_work_packages_forbidden": {"const": true}, "checkpoint_only_work_forbidden": {"const": true}, "bookkeeping_only_work_forbidden": {"const": true}, "catalog_replenishment_must_not_block_active_execution": {"const": true}, "catalog_replenishment_must_respect_single_active_pr_policy": {"const": true}, "catalog_changes_require_schema_validation": {"const": true}, "catalog_changes_require_ci": {"const": true}, "catalog_changes_require_reviewable_pr": {"const": true}, "state_driven_triggers": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string"}}, "forbidden_refresh_triggers": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string"}}, "when_active_pr_exists": {"type": "object", "additionalProperties": false, "required": ["allowed", "forbidden"], "properties": {"allowed": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"type": "string"}}, "forbidden": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"type": "string"}}}}, "when_no_active_pr_exists": {"type": "object", "additionalProperties": false, "required": ["allowed"], "properties": {"allowed": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"type": "string"}}}}}},
    "work_package_requirements": {"type": "object", "additionalProperties": false, "required": ["measurable_current_state_required", "measurable_target_state_required", "capability_level_outcome_required", "truth_boundaries_required", "acceptance_gates_required", "negative_fixture_coverage_when_applicable", "estimated_percentage_is_reporting_only"], "properties": {"measurable_current_state_required": {"const": true}, "measurable_target_state_required": {"const": true}, "capability_level_outcome_required": {"const": true}, "truth_boundaries_required": {"const": true}, "acceptance_gates_required": {"const": true}, "negative_fixture_coverage_when_applicable": {"const": true}, "estimated_percentage_is_reporting_only": {"const": true}}},
    "global_boundaries": {"type": "object", "additionalProperties": false, "required": ["submitted_evidence_created_by_catalog", "issue_8_mutation_allowed_by_catalog", "real_pilot_execution_allowed_by_catalog", "catalog_completion_is_evidence_validation", "ci_success_is_responsive_correctness_evidence", "production_ready", "release_ready", "live_render_validated", "export_json_validated", "accessibility_passed", "pixel_perfect", "responsive_correctness_validated"], "properties": {"submitted_evidence_created_by_catalog": {"const": false}, "issue_8_mutation_allowed_by_catalog": {"const": false}, "real_pilot_execution_allowed_by_catalog": {"const": false}, "catalog_completion_is_evidence_validation": {"const": false}, "ci_success_is_responsive_correctness_evidence": {"const": false}, "production_ready": {"const": false}, "release_ready": {"const": false}, "live_render_validated": {"const": false}, "export_json_validated": {"const": false}, "accessibility_passed": {"const": false}, "pixel_perfect": {"const": false}, "responsive_correctness_validated": {"const": false}}},
    "measurement": {"type": "object", "additionalProperties": false, "required": ["statement", "measurement", "measurable"], "properties": {"statement": {"type": "string", "minLength": 30}, "measurement": {"type": "string", "minLength": 30}, "measurable": {"const": true}}},
    "reporting": {"type": "object", "additionalProperties": false, "required": ["estimated_completion_percentage", "estimated_percentage_is_reporting_only"], "properties": {"estimated_completion_percentage": {"type": "integer", "minimum": 0, "maximum": 100}, "estimated_percentage_is_reporting_only": {"const": true}}},
    "false_boundary": {"type": "object", "additionalProperties": true},
    "pr_slice": {"type": "object", "additionalProperties": false, "required": ["slice_id", "title", "layer", "objective", "review_boundary"], "properties": {"slice_id": {"type": "string", "pattern": "^WP-RESP-[0-9]{3}/PR-[A-Z]$"}, "title": {"type": "string", "minLength": 1}, "layer": {"type": "string"}, "objective": {"type": "string", "minLength": 20}, "review_boundary": {"type": "string", "minLength": 20}}},
    "work_package": {"type": "object", "additionalProperties": false, "required": ["id", "title", "capability_area", "current_state", "target_state", "measurable_current_state", "measurable_target_state", "target_capability", "expected_project_delta", "selectable", "ready_state", "priority", "reporting", "allowed_work", "forbidden_work", "must_deliver", "must_preserve", "evidence_boundary", "readiness_boundary", "definition_of_done", "quality_gates", "split_rule", "allowed_pr_slices", "blocked_if", "completion_record_requirements", "unblocks_work_package_ids"], "properties": {"id": {"type": "string", "pattern": "^WP-RESP-[0-9]{3}$"}, "title": {"type": "string", "minLength": 1}, "capability_area": {"type": "string"}, "current_state": {"type": "string", "minLength": 30}, "target_state": {"type": "string", "minLength": 30}, "measurable_current_state": {"$ref": "#/$defs/measurement"}, "measurable_target_state": {"$ref": "#/$defs/measurement"}, "target_capability": {"$ref": "#/$defs/measurement"}, "expected_project_delta": {"type": "string", "minLength": 40}, "selectable": {"type": "boolean"}, "ready_state": {"enum": ["ready", "blocked", "active", "completed", "governance"]}, "priority": {"type": "integer", "minimum": 1, "maximum": 100}, "reporting": {"$ref": "#/$defs/reporting"}, "allowed_work": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "forbidden_work": {"type": "array", "minItems": 5, "items": {"type": "string"}}, "must_deliver": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "must_preserve": {"type": "array", "minItems": 4, "items": {"type": "string"}}, "evidence_boundary": {"$ref": "#/$defs/false_boundary"}, "readiness_boundary": {"$ref": "#/$defs/false_boundary"}, "definition_of_done": {"type": "array", "minItems": 3, "items": {"type": "string"}}, "quality_gates": {"type": "array", "minItems": 5, "items": {"type": "string"}}, "split_rule": {"type": "object"}, "allowed_pr_slices": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/pr_slice"}}, "blocked_if": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "completion_record_requirements": {"type": "array", "minItems": 5, "items": {"type": "string"}}, "unblocks_work_package_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}, "maintenance_type": {"type": "string"}}}
  }
}
