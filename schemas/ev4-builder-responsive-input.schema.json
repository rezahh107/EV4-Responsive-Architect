{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive-architect.local/schemas/ev4-builder-responsive-input.schema.json",
  "title": "EV4 Builder to Responsive Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_packet_ref",
    "project_gate_ref",
    "selected_candidate_id",
    "builder_output_ref",
    "builder_evidence",
    "viewport_evidence",
    "responsive_intake_decision",
    "decision_lineage",
    "forbidden_claims"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "responsive_intake_decision": {
            "properties": {
              "intake_allowed": {
                "const": true
              }
            },
            "required": [
              "intake_allowed"
            ]
          }
        },
        "required": [
          "responsive_intake_decision"
        ]
      },
      "then": {
        "properties": {
          "project_gate_ref": {
            "properties": {
              "gate_status": {
                "const": "verified"
              }
            },
            "required": [
              "gate_status"
            ]
          },
          "viewport_evidence": {
            "properties": {
              "desktop": {
                "properties": {
                  "evidence_status": {
                    "const": "provided"
                  }
                },
                "required": [
                  "evidence_status"
                ]
              },
              "tablet": {
                "properties": {
                  "evidence_status": {
                    "const": "provided"
                  }
                },
                "required": [
                  "evidence_status"
                ]
              },
              "mobile": {
                "properties": {
                  "evidence_status": {
                    "const": "provided"
                  }
                },
                "required": [
                  "evidence_status"
                ]
              }
            },
            "required": [
              "desktop",
              "tablet",
              "mobile"
            ]
          }
        },
        "required": [
          "project_gate_ref",
          "viewport_evidence"
        ]
      }
    }
  ],
  "properties": {
    "schema": {
      "const": "ev4-builder-responsive-input@0.1.0"
    },
    "source_packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "project_gate_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "gate_status",
        "gate_hash"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "gate_status": {
          "enum": [
            "verified",
            "blocked"
          ]
        },
        "gate_hash": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "selected_candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "builder_output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_id",
        "artifact_ref",
        "artifact_hash"
      ],
      "properties": {
        "output_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "artifact_hash": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "builder_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_batch_ref",
        "execution_evidence_ref",
        "layout_check_ref",
        "completion_gate_ref"
      ],
      "properties": {
        "action_batch_ref": {
          "type": "string",
          "minLength": 1
        },
        "execution_evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "layout_check_ref": {
          "type": "string",
          "minLength": 1
        },
        "completion_gate_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "viewport_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desktop",
        "tablet",
        "mobile"
      ],
      "properties": {
        "desktop": {
          "$ref": "#/$defs/viewportEvidence"
        },
        "tablet": {
          "$ref": "#/$defs/viewportEvidence"
        },
        "mobile": {
          "$ref": "#/$defs/viewportEvidence"
        }
      }
    },
    "responsive_intake_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_allowed",
        "reason",
        "claim_boundary"
      ],
      "properties": {
        "intake_allowed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "claim_boundary": {
          "const": "input eligibility only; not responsive correctness evidence"
        }
      }
    },
    "forbidden_claims": {
      "type": "array",
      "$comment": "Completeness is intentionally coupled to minItems/maxItems and the enum below. When adding or removing a forbidden claim, update both size constraints and REQUIRED_FORBIDDEN_CLAIMS in validation/e2e/run_builder_responsive_input_boundary_check.py.",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "production_ready",
          "release_ready",
          "pixel_perfect",
          "live_render_validated",
          "export_json_validated",
          "accessibility_passed",
          "responsive_correctness_validated",
          "ci_success_as_frontend_evidence"
        ]
      }
    },
    "decision_lineage": {
      "$ref": "#/$defs/decisionLineage"
    }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "viewportEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref",
        "evidence_status"
      ],
      "properties": {
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "evidence_status": {
          "enum": [
            "provided",
            "blocked",
            "not_applicable"
          ]
        }
      }
    },
    "decisionLineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_family",
        "decision_card_ref",
        "selected_option",
        "rejected_options",
        "evidence_refs",
        "evidence_state",
        "consumer_stage"
      ],
      "properties": {
        "decision_family": {
          "type": "string",
          "minLength": 1
        },
        "decision_card_ref": {
          "type": "string",
          "minLength": 1
        },
        "selected_option": {
          "type": "string",
          "minLength": 1
        },
        "rejected_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_state": {
          "enum": [
            "validated",
            "provided",
            "insufficient_evidence",
            "conflict_flagged",
            "reopen_required"
          ]
        },
        "consumer_stage": {
          "enum": [
            "responsive_intake",
            "responsive_validation_output",
            "runtime_evidence_conflict",
            "project_gate_handoff"
          ]
        }
      }
    }
  }
}
