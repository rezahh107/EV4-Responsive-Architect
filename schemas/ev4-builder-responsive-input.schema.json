{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive-architect.local/schemas/ev4-builder-responsive-input.schema.json",
  "title": "EV4 Builder to Responsive Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_packet_ref",
    "project_gate_ref",
    "selected_candidate_id",
    "builder_output_ref",
    "builder_evidence",
    "viewport_evidence",
    "responsive_intake_decision",
    "forbidden_claims"
  ],
  "properties": {
    "schema": {"const": "ev4-builder-responsive-input@0.1.0"},
    "source_packet_ref": {"type": "string", "minLength": 1},
    "project_gate_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "gate_status", "gate_hash"],
      "properties": {
        "gate_id": {"type": "string", "minLength": 1},
        "gate_status": {"enum": ["verified", "blocked"]},
        "gate_hash": {"type": "string", "minLength": 1}
      }
    },
    "selected_candidate_id": {"type": "string", "minLength": 1},
    "builder_output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_id", "artifact_ref", "artifact_hash"],
      "properties": {
        "output_id": {"type": "string", "minLength": 1},
        "artifact_ref": {"type": "string", "minLength": 1},
        "artifact_hash": {"type": "string", "minLength": 1}
      }
    },
    "builder_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_batch_ref", "execution_evidence_ref", "layout_check_ref", "completion_gate_ref"],
      "properties": {
        "action_batch_ref": {"type": "string", "minLength": 1},
        "execution_evidence_ref": {"type": "string", "minLength": 1},
        "layout_check_ref": {"type": "string", "minLength": 1},
        "completion_gate_ref": {"type": "string", "minLength": 1}
      }
    },
    "viewport_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desktop", "tablet", "mobile"],
      "properties": {
        "desktop": {"$ref": "#/$defs/viewportEvidence"},
        "tablet": {"$ref": "#/$defs/viewportEvidence"},
        "mobile": {"$ref": "#/$defs/viewportEvidence"}
      }
    },
    "responsive_intake_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intake_allowed", "reason", "claim_boundary"],
      "properties": {
        "intake_allowed": {"type": "boolean"},
        "reason": {"type": "string", "minLength": 1},
        "claim_boundary": {"const": "input eligibility only; not responsive correctness evidence"}
      }
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "production_ready",
          "release_ready",
          "pixel_perfect",
          "live_render_validated",
          "export_json_validated",
          "accessibility_passed",
          "responsive_correctness_validated",
          "ci_success_as_frontend_evidence"
        ]
      }
    }
  },
  "$defs": {
    "viewportEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_ref", "evidence_status"],
      "properties": {
        "evidence_ref": {"type": "string", "minLength": 1},
        "evidence_status": {"enum": ["provided", "blocked", "not_applicable"]}
      }
    }
  }
}
