{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-accessibility-gate.schema.json",
  "title": "EV4 Responsive Accessibility Reading Order Gate",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.:/@-]+$" },
    "trigger": { "enum": ["visual_order_changes", "custom_order_used", "reverse_direction_used", "hide_on_mobile", "duplicate_mobile_section", "absolute_or_overlay_positioning", "connector_simplification"] },
    "contentRole": { "enum": ["meaningful", "decorative", "interactive", "unknown"] },
    "viewport": { "enum": ["desktop", "tablet", "mobile", "custom", "unknown"] },
    "checkStatus": { "enum": ["pass", "fail", "unknown", "not_applicable"] },
    "risk": { "enum": ["low", "medium", "high", "unknown", "not_applicable"] },
    "followUp": { "enum": ["builder_verification", "DOM_order_check", "keyboard_test", "main_pipeline_rerun"] }
  },
  "required": ["schema", "gate_id", "gate_status", "applies_because", "affected_items", "checks", "risk_summary", "required_follow_up", "production_ready_claim_allowed"],
  "properties": {
    "schema": { "const": "ev4-responsive-accessibility-gate@1.0.0" },
    "gate_id": { "$ref": "#/$defs/id" },
    "gate_status": { "enum": ["not_applicable", "pass", "pass_with_visible_risk", "fail_requires_responsive_repair", "fail_requires_implementation_repair", "fail_requires_main_pipeline_rerun", "blocked_missing_evidence"] },
    "applies_because": { "type": "array", "items": { "$ref": "#/$defs/trigger" }, "uniqueItems": true },
    "affected_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "structure_label", "content_role", "viewport_scope", "repair_step_ids"],
        "properties": {
          "node_id": { "$ref": "#/$defs/id" },
          "structure_label": { "type": "string", "minLength": 1 },
          "content_role": { "$ref": "#/$defs/contentRole" },
          "viewport_scope": { "$ref": "#/$defs/viewport" },
          "repair_step_ids": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true }
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meaningful_content_visibility_preserved", "source_order_risk_recorded", "keyboard_order_risk_recorded", "screen_reader_order_risk_recorded", "tap_target_risk_recorded", "focus_order_risk_recorded", "decoration_hide_safety_checked"],
      "properties": {
        "meaningful_content_visibility_preserved": { "$ref": "#/$defs/checkStatus" },
        "source_order_risk_recorded": { "$ref": "#/$defs/checkStatus" },
        "keyboard_order_risk_recorded": { "$ref": "#/$defs/checkStatus" },
        "screen_reader_order_risk_recorded": { "$ref": "#/$defs/checkStatus" },
        "tap_target_risk_recorded": { "$ref": "#/$defs/checkStatus" },
        "focus_order_risk_recorded": { "$ref": "#/$defs/checkStatus" },
        "decoration_hide_safety_checked": { "$ref": "#/$defs/checkStatus" }
      }
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_order_risk", "keyboard_order_risk", "screen_reader_order_risk", "tap_target_risk"],
      "properties": {
        "source_order_risk": { "$ref": "#/$defs/risk" },
        "keyboard_order_risk": { "$ref": "#/$defs/risk" },
        "screen_reader_order_risk": { "$ref": "#/$defs/risk" },
        "tap_target_risk": { "$ref": "#/$defs/risk" }
      }
    },
    "required_follow_up": { "type": "array", "items": { "$ref": "#/$defs/followUp" }, "uniqueItems": true },
    "risk_notes": { "type": "array", "items": { "type": "string" } },
    "production_ready_claim_allowed": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "gate_status": { "enum": ["pass_with_visible_risk", "fail_requires_responsive_repair", "fail_requires_implementation_repair", "fail_requires_main_pipeline_rerun", "blocked_missing_evidence"] } } },
      "then": { "properties": { "production_ready_claim_allowed": { "const": false } } }
    }
  ]
}
