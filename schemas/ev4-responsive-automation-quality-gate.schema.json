{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-responsive-automation-quality-gate.schema.json",
  "title": "EV4 Responsive Automation Quality Gate Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "quality_principles",
    "deterministic_review_policy",
    "cross_critique_policy",
    "delayed_review_policy",
    "pr_reconciliation_policy",
    "completion_policy",
    "sensitive_task_types",
    "forbidden_quality_shortcuts"
  ],
  "properties": {
    "schema": {
      "const": "ev4-responsive-automation-quality-gate@1.0.0"
    },
    "status": {
      "enum": [
        "active",
        "draft"
      ]
    },
    "quality_principles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "self_critique_is_insufficient",
        "deterministic_checks_required",
        "cross_critique_required_for_sensitive_tasks",
        "ci_or_explicit_no_ci_reason_required",
        "quality_record_required_for_completion"
      ],
      "properties": {
        "self_critique_is_insufficient": {
          "const": true
        },
        "deterministic_checks_required": {
          "const": true
        },
        "cross_critique_required_for_sensitive_tasks": {
          "const": true
        },
        "ci_or_explicit_no_ci_reason_required": {
          "const": true
        },
        "quality_record_required_for_completion": {
          "const": true
        }
      }
    },
    "deterministic_review_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_checks",
        "failed_required_check_effect"
      ],
      "properties": {
        "required_checks": {
          "type": "array",
          "minItems": 9,
          "uniqueItems": true,
          "items": {
            "enum": [
              "acceptance_criteria_checked",
              "scope_respected",
              "forbidden_work_absent",
              "ci_checked_or_no_ci_reason_recorded",
              "artifacts_listed",
              "queue_state_checked",
              "ledger_state_checked",
              "stale_reference_search_done",
              "delayed_bot_review_window_checked",
              "boundary_assertions_checked"
            ]
          }
        },
        "failed_required_check_effect": {
          "const": "block_completion_or_create_follow_up"
        }
      }
    },
    "cross_critique_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_role",
        "prompt_separation_required",
        "low_temperature_policy",
        "sensitive_task_effect"
      ],
      "properties": {
        "reviewer_role": {
          "const": "strict_pessimistic_reviewer"
        },
        "prompt_separation_required": {
          "const": true
        },
        "low_temperature_policy": {
          "enum": [
            "temperature_0_1_recommended",
            "deterministic_external_step_required"
          ]
        },
        "sensitive_task_effect": {
          "const": "completion_blocked_until_cross_critique_recorded"
        }
      }
    },
    "delayed_review_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "minimum_wait_minutes_before_merge",
        "review_sources_to_check",
        "block_merge_on_unresolved_high_priority_review",
        "allowed_outcome_if_feedback_arrives_after_merge"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "minimum_wait_minutes_before_merge": {
          "type": "integer",
          "minimum": 10
        },
        "review_sources_to_check": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "github_review_threads",
              "gemini-code-assist[bot]",
              "human_reviewer"
            ]
          }
        },
        "block_merge_on_unresolved_high_priority_review": {
          "const": true
        },
        "allowed_outcome_if_feedback_arrives_after_merge": {
          "const": "create_follow_up_task_and_record_in_ledger"
        }
      }
    },
    "pr_reconciliation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "runs_before_new_task_selection",
        "single_active_automation_pr",
        "open_automation_pr_effect",
        "review_handling_counts_as_queue_task",
        "previous_pr_resolution_order",
        "broad_feedback_policy",
        "forbidden_during_open_pr"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "runs_before_new_task_selection": {
          "const": true
        },
        "single_active_automation_pr": {
          "const": true
        },
        "open_automation_pr_effect": {
          "const": "block_new_queue_task_until_reconciled"
        },
        "review_handling_counts_as_queue_task": {
          "const": false
        },
        "previous_pr_resolution_order": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "inspect_open_automation_prs",
              "check_ci_status",
              "check_mergeability_and_head_sha",
              "read_pr_comments_and_review_comments",
              "evaluate_gemini_or_reviewer_feedback",
              "fix_small_in_scope_feedback_on_same_pr",
              "rerun_ci_after_fixes",
              "merge_when_green_mergeable_and_no_unresolved_feedback",
              "stop_after_merge_unless_next_task_is_trivial_and_no_state_drift"
            ]
          }
        },
        "broad_feedback_policy": {
          "const": "create_backlog_or_queue_candidate_do_not_force_into_current_pr"
        },
        "forbidden_during_open_pr": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "start_new_queue_task",
              "create_parallel_automation_pr",
              "overwrite_queue_from_stale_snapshot",
              "merge_without_comment_check",
              "treat_review_comment_as_domain_evidence"
            ]
          }
        }
      }
    },
    "completion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completion_allowed_requires",
        "blocked_if"
      ],
      "properties": {
        "completion_allowed_requires": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "deterministic_checks_pass",
              "self_critique_recorded",
              "cross_critique_completed_when_required",
              "delayed_reviewer_window_checked",
              "unfixed_p0_or_p1_findings_absent",
              "follow_up_tasks_created_when_needed",
              "boundary_assertions_present"
            ]
          }
        },
        "blocked_if": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "self_critique_only_for_sensitive_task",
              "deterministic_check_failed_without_follow_up",
              "ci_required_but_missing",
              "cross_critique_required_but_missing",
              "delayed_reviewer_feedback_unchecked",
              "unfixed_p0_or_p1_finding_without_follow_up",
              "open_automation_pr_unreconciled"
            ]
          }
        }
      }
    },
    "sensitive_task_types": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "schema_hardening",
          "automation_control",
          "readiness_gate",
          "sample_vs_real_safety",
          "risk_priority_engine",
          "evidence_boundary",
          "production_boundary",
          "ci_workflow"
        ]
      }
    },
    "forbidden_quality_shortcuts": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "self_critique_only_completion",
          "green_ci_as_quality_proof",
          "merged_pr_as_evidence_truth",
          "unstructured_reviewer_opinion_as_gate",
          "silent_follow_up_omission",
          "parallel_automation_prs_without_reconciliation",
          "gemini_review_as_independent_queue_task"
        ]
      }
    }
  }
}
