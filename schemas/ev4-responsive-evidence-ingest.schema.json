{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-evidence-ingest.schema.json",
  "title": "EV4 Responsive Evidence Ingest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.:/@-]+$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "viewport": { "enum": ["desktop", "tablet", "mobile", "custom", "unknown"] },
    "confidenceCap": { "enum": ["low", "medium", "high", "high_for_structure_medium_for_visual"] },
    "yesNoLimited": { "enum": ["yes", "no", "limited"] },
    "evidenceLabel": { "enum": ["SUPPORTED_EVIDENCE", "PARTIALLY_SUPPORTED_EVIDENCE", "INFERRED_EVIDENCE", "ABSENT_EVIDENCE", "CONTRADICTED_EVIDENCE", "UNRESOLVED_CONFLICT", "NON_APPLICABLE"] },
    "evidenceType": { "enum": ["static_screenshot", "frontend_screenshot", "editor_screenshot", "frontend_video", "resize_sweep", "elementor_export_json", "dom_inspector_note", "computed_style_note", "browser_console_note", "user_observation", "user_declaration", "builder_feedback"] },
    "captureSource": { "enum": ["frontend", "elementor_editor", "export", "browser_devtools", "user_statement", "mixed", "unknown"] },
    "qualityLevel": { "enum": ["L1_static_visual_only", "L2_frontend_visual_with_viewport", "L3_resize_sweep_or_video", "L4_dom_or_export_structure", "L5_live_render_plus_dom_plus_visual"] }
  },
  "required": ["schema", "evidence_items", "evidence_quality_map"],
  "properties": {
    "schema": { "const": "ev4-responsive-evidence-ingest@1.0.0" },
    "evidence_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "evidence_type", "viewport_label", "capture_source", "source_ref", "supplied_by", "timestamp_or_capture_order", "known_limitations", "privacy_review_required", "evidence_label"],
        "properties": {
          "evidence_id": { "$ref": "#/$defs/id" },
          "evidence_type": { "$ref": "#/$defs/evidenceType" },
          "viewport_label": { "$ref": "#/$defs/viewport" },
          "viewport_width_px": { "type": ["integer", "null"], "minimum": 1 },
          "viewport_height_px": { "type": ["integer", "null"], "minimum": 1 },
          "capture_source": { "$ref": "#/$defs/captureSource" },
          "source_ref": { "$ref": "#/$defs/nonEmptyString" },
          "supplied_by": { "enum": ["user", "builder", "validator", "automated_capture", "unknown"] },
          "timestamp_or_capture_order": { "$ref": "#/$defs/nonEmptyString" },
          "file_hash_if_available": { "type": ["string", "null"], "pattern": "^(sha256:[a-fA-F0-9]{64})?$" },
          "known_limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "privacy_review_required": { "type": "boolean" },
          "evidence_label": { "$ref": "#/$defs/evidenceLabel" }
        }
      }
    },
    "evidence_quality_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "quality_level", "can_support", "cannot_support", "confidence_cap", "downstream_allowed_use", "notes"],
        "properties": {
          "evidence_id": { "$ref": "#/$defs/id" },
          "quality_level": { "$ref": "#/$defs/qualityLevel" },
          "can_support": { "$ref": "#/$defs/stringArray" },
          "cannot_support": { "$ref": "#/$defs/stringArray" },
          "confidence_cap": { "$ref": "#/$defs/confidenceCap" },
          "downstream_allowed_use": {
            "type": "object",
            "additionalProperties": false,
            "required": ["observation", "diagnosis", "repair_selection", "validation_claim"],
            "properties": {
              "observation": { "$ref": "#/$defs/yesNoLimited" },
              "diagnosis": { "$ref": "#/$defs/yesNoLimited" },
              "repair_selection": { "$ref": "#/$defs/yesNoLimited" },
              "validation_claim": { "$ref": "#/$defs/yesNoLimited" }
            }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
