{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive.local/schemas/ev4-responsive-evidence-intake-packet.schema.json",
  "title": "EV4 Responsive Evidence Intake Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "packet_status",
    "section_id",
    "selected_candidate_id",
    "main_ev4_handoff",
    "desktop_baseline",
    "evidence_items",
    "breakpoint_inventory",
    "privacy_review",
    "evidence_complete_definition",
    "intake_verdict"
  ],
  "properties": {
    "schema": {
      "const": "ev4-responsive-evidence-intake-packet@1.0.0"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "packet_status": {
      "enum": ["draft", "submitted", "validated", "blocked"]
    },
    "section_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "main_ev4_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_tree_payload_present",
        "implementation_payload_present",
        "final_audit_payload_present",
        "handoff_payload_present",
        "overlay_decoration_map_present",
        "content_editability_map_present",
        "responsive_structure_contract_present",
        "carried_unknowns_visible",
        "audit_flags_visible"
      ],
      "properties": {
        "build_tree_payload_present": {"type": "boolean"},
        "implementation_payload_present": {"type": "boolean"},
        "final_audit_payload_present": {"type": "boolean"},
        "handoff_payload_present": {"type": "boolean"},
        "overlay_decoration_map_present": {"type": "boolean"},
        "content_editability_map_present": {"type": "boolean"},
        "responsive_structure_contract_present": {"type": "boolean"},
        "carried_unknowns_visible": {"type": "boolean"},
        "audit_flags_visible": {"type": "boolean"},
        "source_ref": {"type": "string"},
        "payload_identity_hash": {"type": "string"}
      }
    },
    "desktop_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "root_class", "viewport_label_or_width", "must_not_regress", "known_acceptable_issues"],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1},
        "root_class": {"type": "string", "minLength": 1},
        "viewport_label_or_width": {"type": "string", "minLength": 1},
        "must_not_regress": {
          "type": "array",
          "minItems": 5,
          "items": {
            "enum": [
              "meaningful_text_visibility",
              "feature_card_group_integrity",
              "visual_core_presence",
              "connector_layer_containment",
              "no_horizontal_overflow",
              "no_unexpected_desktop_reflow"
            ]
          }
        },
        "known_acceptable_issues": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/evidence_item"}
    },
    "breakpoint_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "confidence", "claim_scope", "breakpoints"],
      "properties": {
        "source": {
          "enum": ["project_settings_or_export_json", "user_declaration", "fallback_default_with_unverified_label"]
        },
        "confidence": {
          "enum": ["high", "medium", "low"]
        },
        "claim_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["may_observe", "may_plan_repair", "may_handoff_controlled", "may_claim_release_ready"],
          "properties": {
            "may_observe": {"type": "boolean"},
            "may_plan_repair": {"type": "boolean"},
            "may_handoff_controlled": {"type": "boolean"},
            "may_claim_release_ready": {"type": "boolean"}
          }
        },
        "breakpoints": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value_status"],
            "properties": {
              "label": {"enum": ["desktop", "tablet", "mobile", "custom"]},
              "width_px": {"type": ["integer", "null"], "minimum": 0},
              "value_status": {"enum": ["verified", "user_declared", "fallback_unverified", "unknown"]}
            }
          }
        }
      }
    },
    "privacy_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "credentials_removed",
        "private_user_data_removed",
        "private_urls_reviewed",
        "client_identifiers_reviewed",
        "reviewer_acknowledgement"
      ],
      "properties": {
        "credentials_removed": {"type": "boolean"},
        "private_user_data_removed": {"type": "boolean"},
        "private_urls_reviewed": {"type": "boolean"},
        "client_identifiers_reviewed": {"type": "boolean"},
        "reviewer_acknowledgement": {"type": "boolean"}
      }
    },
    "evidence_complete_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_required_evidence_ids_present",
        "per_item_quality_present",
        "desktop_must_not_regress_present",
        "breakpoint_claim_scope_present",
        "privacy_review_acknowledged"
      ],
      "properties": {
        "all_required_evidence_ids_present": {"type": "boolean"},
        "per_item_quality_present": {"type": "boolean"},
        "desktop_must_not_regress_present": {"type": "boolean"},
        "breakpoint_claim_scope_present": {"type": "boolean"},
        "privacy_review_acknowledged": {"type": "boolean"}
      }
    },
    "intake_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "missing_required_items", "blocker_conflicts", "pilot_allowed_to_start"],
      "properties": {
        "status": {"enum": ["allowed", "blocked"]},
        "missing_required_items": {"type": "array", "items": {"type": "string"}},
        "blocker_conflicts": {"type": "array", "items": {"type": "string"}},
        "evidence_quality_summary": {"type": "string"},
        "pilot_allowed_to_start": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "capture_source",
        "viewport",
        "quality_level",
        "confidence_cap",
        "can_support",
        "cannot_support",
        "downstream_allowed_use",
        "known_limitations"
      ],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1},
        "file_name": {"type": "string"},
        "evidence_type": {
          "enum": ["frontend_screenshot", "editor_screenshot", "elementor_export_json", "user_declaration", "devtools_note", "computed_style_note"]
        },
        "capture_source": {
          "enum": ["frontend", "elementor_editor", "export", "user", "browser_devtools", "unknown"]
        },
        "viewport": {
          "enum": ["desktop", "tablet", "mobile", "custom", "unknown"]
        },
        "viewport_width": {"type": ["integer", "null"], "minimum": 0},
        "quality_level": {
          "enum": ["L1_static_visual_only", "L2_frontend_visual_with_viewport", "L3_resize_sweep_or_video", "L4_dom_or_export_structure", "L5_live_render_plus_dom_plus_visual"]
        },
        "confidence_cap": {"enum": ["low", "medium", "high", "high_for_structure_medium_for_visual"]},
        "can_support": {"type": "array", "items": {"type": "string"}},
        "cannot_support": {"type": "array", "items": {"type": "string"}},
        "downstream_allowed_use": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observation", "diagnosis", "repair_selection", "validation_claim"],
          "properties": {
            "observation": {"type": "boolean"},
            "diagnosis": {"enum": ["no", "limited", "yes"]},
            "repair_selection": {"enum": ["no", "limited", "yes"]},
            "validation_claim": {"enum": ["no", "limited", "yes"]}
          }
        },
        "known_limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
