{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-handoff-export-boundary-manifest.schema.json",
  "title": "EV4 Responsive Handoff Export Boundary Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "source_handoff_ref",
    "source_packet_ref",
    "selected_route_ref",
    "relationship_classification_ref",
    "contract_refs",
    "expected_artifact_classes",
    "validation_plan_refs",
    "unresolved_unknowns",
    "blocking_conflicts",
    "boundary_assertions"
  ],
  "properties": {
    "schema": {
      "const": "ev4-responsive-handoff-export-boundary-manifest@0.1.0"
    },
    "status": {
      "const": "eligible_for_repository_validation"
    },
    "source_handoff_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "selected_route_ref": {
      "type": "string",
      "minLength": 1
    },
    "relationship_classification_ref": {
      "type": "string",
      "minLength": 1
    },
    "contract_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "responsive_handoff",
        "viewport_display"
      ],
      "properties": {
        "responsive_handoff": {
          "type": "string",
          "minLength": 1
        },
        "viewport_display": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_artifact_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "allOf": [
        {"contains": {"const": "responsive_tree_output"}},
        {"contains": {"const": "breakpoint_overrides"}},
        {"contains": {"const": "viewport_display_contract"}},
        {"contains": {"const": "content_gate"}},
        {"contains": {"const": "builder_handoff"}},
        {"contains": {"const": "validation_plan"}},
        {"contains": {"const": "final_review"}}
      ]
    },
    "validation_plan_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unresolved_unknowns": {
      "type": "array",
      "maxItems": 0
    },
    "blocking_conflicts": {
      "type": "array",
      "maxItems": 0
    },
    "boundary_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_evidence_created",
        "issue_8_mutated",
        "pilot_executed_or_authorized",
        "production_ready",
        "release_ready",
        "live_render_validated",
        "export_validated",
        "accessibility_passed",
        "pixel_perfect",
        "responsive_correctness_validated",
        "ci_success_treated_as_domain_evidence"
      ],
      "properties": {
        "submitted_evidence_created": {"const": false},
        "issue_8_mutated": {"const": false},
        "pilot_executed_or_authorized": {"const": false},
        "production_ready": {"const": false},
        "release_ready": {"const": false},
        "live_render_validated": {"const": false},
        "export_validated": {"const": false},
        "accessibility_passed": {"const": false},
        "pixel_perfect": {"const": false},
        "responsive_correctness_validated": {"const": false},
        "ci_success_treated_as_domain_evidence": {"const": false}
      }
    }
  }
}
