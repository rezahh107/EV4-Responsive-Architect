{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-main-input.schema.json",
  "title": "EV4 Responsive Main Pipeline Input",
  "description": "Production Responsive intake wrapper. The authoritative production handoff is Builder output and build evidence, with explicit CE and Builder provenance preserved by the Project Gate.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.:/@-]+$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "nonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "contentHash": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" },
    "payloadStatus": { "enum": ["present", "missing", "stale", "schema_mismatch", "identity_conflict"] },
    "refOrNull": { "type": ["string", "null"] },
    "upstreamProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_handoff_source",
        "builder_provenance",
        "ce_provenance",
        "visual_governance_provenance",
        "builder_validation_claims"
      ],
      "properties": {
        "production_handoff_source": { "const": "builder_output_and_build_evidence" },
        "builder_provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "builder_package_schema",
            "builder_output_ref",
            "builder_input_authorization_digest",
            "build_evidence_refs"
          ],
          "properties": {
            "builder_package_schema": { "const": "ev4-builder-context-package@1.0.0" },
            "builder_output_ref": { "$ref": "#/$defs/nonEmptyString" },
            "builder_input_authorization_digest": { "$ref": "#/$defs/contentHash" },
            "build_evidence_refs": { "$ref": "#/$defs/nonEmptyStringArray" }
          }
        },
        "ce_provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ce_package_schema",
            "ce_package_ref",
            "constructability_status",
            "builder_decisions_required",
            "blocking_dependencies_count"
          ],
          "properties": {
            "ce_package_schema": { "const": "ev4-builder-executable-package@1.0.0" },
            "ce_package_ref": { "$ref": "#/$defs/nonEmptyString" },
            "constructability_status": { "const": "executable_ready" },
            "builder_decisions_required": { "const": 0 },
            "blocking_dependencies_count": { "const": 0 }
          }
        },
        "visual_governance_provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "golden_reference_contract_id",
            "golden_reference_contract_hash",
            "spatial_lexicon_version_used",
            "visual_tolerance_policy_ref",
            "build_intent_brief_ref",
            "reference_paradigm_lock_ref",
            "paradigm_to_structure_map_ref"
          ],
          "properties": {
            "golden_reference_contract_id": { "$ref": "#/$defs/nonEmptyString" },
            "golden_reference_contract_hash": { "$ref": "#/$defs/contentHash" },
            "spatial_lexicon_version_used": { "$ref": "#/$defs/nonEmptyString" },
            "visual_tolerance_policy_ref": { "$ref": "#/$defs/nonEmptyString" },
            "build_intent_brief_ref": { "$ref": "#/$defs/nonEmptyString" },
            "reference_paradigm_lock_ref": { "$ref": "#/$defs/nonEmptyString" },
            "paradigm_to_structure_map_ref": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "builder_validation_claims": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "builder_runtime_intake_authorized",
            "visual_reference_prerequisites_present",
            "build_completed",
            "live_render_validated",
            "export_validated",
            "production_ready_allowed"
          ],
          "properties": {
            "builder_runtime_intake_authorized": { "const": true },
            "visual_reference_prerequisites_present": { "const": true },
            "build_completed": { "type": "boolean" },
            "live_render_validated": { "type": "boolean" },
            "export_validated": { "type": "boolean" },
            "production_ready_allowed": { "const": false }
          }
        }
      }
    }
  },
  "required": [
    "schema",
    "input_payload_id",
    "selected_candidate_id",
    "selected_candidate_family",
    "payload_identity_hashes",
    "required_main_pipeline_inputs",
    "upstream_provenance",
    "inherited_baseline",
    "inherited_unknowns",
    "inherited_audit_flags",
    "inherited_repair_routes",
    "validation_claims_imported",
    "input_authorization_status",
    "responsive_pipeline_allowed_to_start",
    "stop_reason_if_blocked"
  ],
  "properties": {
    "$schema_file": { "$ref": "#/$defs/nonEmptyString" },
    "schema": { "const": "ev4-responsive-main-input@1.0.0" },
    "input_payload_id": { "$ref": "#/$defs/id" },
    "selected_candidate_id": { "$ref": "#/$defs/nonEmptyString" },
    "selected_candidate_family": { "$ref": "#/$defs/nonEmptyString" },
    "payload_identity_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Recommendation_Payload", "Build_Tree_Payload", "Implementation_Payload", "Final_Audit_Payload", "Handoff_Payload"],
      "properties": {
        "Recommendation_Payload": { "$ref": "#/$defs/contentHash" },
        "Build_Tree_Payload": { "$ref": "#/$defs/contentHash" },
        "Implementation_Payload": { "$ref": "#/$defs/contentHash" },
        "Final_Audit_Payload": { "$ref": "#/$defs/contentHash" },
        "Handoff_Payload": { "$ref": "#/$defs/contentHash" }
      }
    },
    "required_main_pipeline_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Recommendation_Payload", "Build_Tree_Payload", "Implementation_Payload", "Final_Audit_Payload", "Handoff_Payload", "EV4_DEBUG_TRACE"],
      "properties": {
        "Recommendation_Payload": { "$ref": "#/$defs/payloadStatus" },
        "Build_Tree_Payload": { "$ref": "#/$defs/payloadStatus" },
        "Implementation_Payload": { "$ref": "#/$defs/payloadStatus" },
        "Final_Audit_Payload": { "$ref": "#/$defs/payloadStatus" },
        "Handoff_Payload": { "$ref": "#/$defs/payloadStatus" },
        "EV4_DEBUG_TRACE": { "$ref": "#/$defs/payloadStatus" }
      }
    },
    "upstream_provenance": { "$ref": "#/$defs/upstreamProvenance" },
    "inherited_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structure_tree_ref", "node_id_map_ref", "class_map_ref", "content_editability_map_ref", "overlay_decoration_map_ref", "responsive_structure_contract_ref"],
      "properties": {
        "structure_tree_ref": { "$ref": "#/$defs/refOrNull" },
        "node_id_map_ref": { "$ref": "#/$defs/refOrNull" },
        "class_map_ref": { "$ref": "#/$defs/refOrNull" },
        "content_editability_map_ref": { "$ref": "#/$defs/refOrNull" },
        "overlay_decoration_map_ref": { "$ref": "#/$defs/refOrNull" },
        "responsive_structure_contract_ref": { "$ref": "#/$defs/refOrNull" }
      }
    },
    "inherited_unknowns": { "$ref": "#/$defs/stringArray" },
    "inherited_audit_flags": { "$ref": "#/$defs/stringArray" },
    "inherited_repair_routes": { "$ref": "#/$defs/stringArray" },
    "validation_claims_imported": { "$ref": "#/$defs/stringArray" },
    "input_authorization_status": { "enum": ["authorized", "blocked_missing_payload", "blocked_schema_mismatch", "blocked_identity_conflict", "blocked_stale_payload", "routed_to_main_pipeline"] },
    "responsive_pipeline_allowed_to_start": { "type": "boolean" },
    "stop_reason_if_blocked": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "input_authorization_status": { "const": "authorized" } } },
      "then": {
        "properties": {
          "responsive_pipeline_allowed_to_start": { "const": true },
          "stop_reason_if_blocked": { "type": "null" }
        }
      }
    },
    {
      "if": { "not": { "properties": { "input_authorization_status": { "const": "authorized" } } } },
      "then": {
        "properties": {
          "responsive_pipeline_allowed_to_start": { "const": false },
          "stop_reason_if_blocked": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}
