{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive.local/schemas/ev4-responsive-pilot-readiness.schema.json",
  "title": "EV4 Responsive Pilot Readiness Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "readiness_id",
    "source_packet_id",
    "section_id",
    "readiness_status",
    "blocking_reasons",
    "visible_flags",
    "evidence_conflict_summary",
    "required_next_action",
    "validation_boundary",
    "pilot_start_authorization"
  ],
  "properties": {
    "schema": {"const": "ev4-responsive-pilot-readiness@1.0.0"},
    "readiness_id": {"type": "string", "minLength": 1},
    "source_packet_id": {"type": "string", "minLength": 1},
    "section_id": {"type": "string", "minLength": 1},
    "readiness_status": {
      "enum": [
        "ready_for_shadow_mode_pilot",
        "partial_ready_with_visible_flags",
        "blocked_missing_evidence",
        "blocked_conflicting_evidence",
        "blocked_privacy_review_missing",
        "blocked_schema_or_semantic_failure"
      ]
    },
    "blocking_reasons": {
      "type": "array",
      "items": {"$ref": "#/$defs/blocking_reason"}
    },
    "visible_flags": {
      "type": "array",
      "items": {"$ref": "#/$defs/visible_flag"}
    },
    "evidence_conflict_summary": {"$ref": "#/$defs/evidence_conflict_summary"},
    "required_next_action": {
      "enum": [
        "start_shadow_mode_pilot",
        "start_shadow_mode_pilot_with_visible_flags",
        "request_missing_evidence",
        "resolve_conflicting_evidence",
        "complete_privacy_review",
        "repair_schema_or_semantic_packet"
      ]
    },
    "validation_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_elementor_render_validated",
        "export_json_validated",
        "playwright_visual_regression_validated",
        "accessibility_pass_claimed",
        "production_ready_claimed"
      ],
      "properties": {
        "live_elementor_render_validated": {"$ref": "#/$defs/false_claim_boundary"},
        "export_json_validated": {"$ref": "#/$defs/false_claim_boundary"},
        "playwright_visual_regression_validated": {"$ref": "#/$defs/false_claim_boundary"},
        "accessibility_pass_claimed": {"$ref": "#/$defs/false_claim_boundary"},
        "production_ready_claimed": {"$ref": "#/$defs/false_claim_boundary"}
      }
    },
    "pilot_start_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorized",
        "authorization_scope",
        "forbidden_claims",
        "required_carry_forward_flags"
      ],
      "properties": {
        "authorized": {"type": "boolean"},
        "authorization_scope": {
          "enum": [
            "shadow_mode_only",
            "shadow_mode_only_with_visible_flags",
            "not_authorized"
          ]
        },
        "forbidden_claims": {
          "type": "array",
          "minItems": 5,
          "items": {
            "enum": [
              "production_ready",
              "release_ready",
              "live_render_validated",
              "export_json_validated",
              "accessibility_passed",
              "playwright_visual_regression_validated"
            ]
          }
        },
        "required_carry_forward_flags": {
          "type": "array",
          "items": {"$ref": "#/$defs/visible_flag"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"readiness_status": {"const": "ready_for_shadow_mode_pilot"}}},
      "then": {
        "properties": {
          "blocking_reasons": {"maxItems": 0},
          "visible_flags": {"maxItems": 0},
          "evidence_conflict_summary": {
            "properties": {"unresolved_blocking_conflict_count": {"const": 0}}
          },
          "required_next_action": {"const": "start_shadow_mode_pilot"},
          "pilot_start_authorization": {
            "properties": {
              "authorized": {"const": true},
              "authorization_scope": {"const": "shadow_mode_only"},
              "required_carry_forward_flags": {"maxItems": 0}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"readiness_status": {"const": "partial_ready_with_visible_flags"}}},
      "then": {
        "properties": {
          "blocking_reasons": {"maxItems": 0},
          "visible_flags": {"minItems": 1},
          "evidence_conflict_summary": {
            "properties": {"unresolved_blocking_conflict_count": {"const": 0}}
          },
          "required_next_action": {"const": "start_shadow_mode_pilot_with_visible_flags"},
          "pilot_start_authorization": {
            "properties": {
              "authorized": {"const": true},
              "authorization_scope": {"const": "shadow_mode_only_with_visible_flags"},
              "required_carry_forward_flags": {"minItems": 1}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"readiness_status": {"pattern": "^blocked_"}}},
      "then": {
        "properties": {
          "blocking_reasons": {"minItems": 1},
          "pilot_start_authorization": {
            "properties": {
              "authorized": {"const": false},
              "authorization_scope": {"const": "not_authorized"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"readiness_status": {"const": "blocked_missing_evidence"}}},
      "then": {"properties": {"required_next_action": {"const": "request_missing_evidence"}}}
    },
    {
      "if": {"properties": {"readiness_status": {"const": "blocked_conflicting_evidence"}}},
      "then": {
        "properties": {
          "required_next_action": {"const": "resolve_conflicting_evidence"},
          "evidence_conflict_summary": {
            "properties": {"unresolved_blocking_conflict_count": {"minimum": 1}}
          }
        }
      }
    },
    {
      "if": {"properties": {"readiness_status": {"const": "blocked_privacy_review_missing"}}},
      "then": {"properties": {"required_next_action": {"const": "complete_privacy_review"}}}
    },
    {
      "if": {"properties": {"readiness_status": {"const": "blocked_schema_or_semantic_failure"}}},
      "then": {"properties": {"required_next_action": {"const": "repair_schema_or_semantic_packet"}}}
    }
  ],
  "$defs": {
    "blocking_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_code", "severity", "source_ref", "required_resolution"],
      "properties": {
        "reason_code": {
          "enum": [
            "missing_required_evidence",
            "privacy_review_incomplete",
            "selected_candidate_conflict",
            "schema_or_semantic_failure",
            "intake_verdict_does_not_allow_pilot_start",
            "breakpoint_claim_scope_allows_release_ready",
            "evidence_allows_validation_claim"
          ]
        },
        "severity": {"enum": ["blocker", "high"]},
        "source_ref": {"type": "string", "minLength": 1},
        "required_resolution": {"type": "string", "minLength": 1}
      }
    },
    "visible_flag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag_code", "severity", "source_ref", "required_handling"],
      "properties": {
        "flag_code": {
          "enum": [
            "breakpoint_source_not_export_verified",
            "visual_only_evidence",
            "no_live_render_evidence",
            "no_export_json_evidence",
            "accessibility_not_validated"
          ]
        },
        "severity": {"enum": ["medium", "minor", "note"]},
        "source_ref": {"type": "string", "minLength": 1},
        "required_handling": {"type": "string", "minLength": 1}
      }
    },
    "evidence_conflict_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unresolved_blocking_conflict_count",
        "resolved_conflict_count",
        "conflict_records"
      ],
      "properties": {
        "unresolved_blocking_conflict_count": {"type": "integer", "minimum": 0},
        "resolved_conflict_count": {"type": "integer", "minimum": 0},
        "conflict_records": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence_conflict_record"}
        }
      }
    },
    "evidence_conflict_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conflict_id",
        "conflict_status",
        "source_refs",
        "source_priority_applied",
        "winning_source",
        "resolution_rationale",
        "downstream_effect"
      ],
      "properties": {
        "conflict_id": {"type": "string", "minLength": 1},
        "conflict_status": {"enum": ["unresolved_blocking", "resolved", "not_a_conflict"]},
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "source_priority_applied": {"type": "boolean"},
        "winning_source": {"type": ["string", "null"]},
        "resolution_rationale": {"type": "string"},
        "downstream_effect": {"enum": ["blocked", "visible_flag", "clear"]}
      },
      "allOf": [
        {
          "if": {"properties": {"conflict_status": {"const": "unresolved_blocking"}}},
          "then": {
            "properties": {
              "source_priority_applied": {"const": false},
              "winning_source": {"const": null},
              "downstream_effect": {"const": "blocked"}
            }
          }
        },
        {
          "if": {"properties": {"conflict_status": {"const": "resolved"}}},
          "then": {
            "properties": {
              "source_priority_applied": {"const": true},
              "winning_source": {"type": "string", "minLength": 1},
              "resolution_rationale": {"type": "string", "minLength": 1},
              "downstream_effect": {"enum": ["visible_flag", "clear"]}
            }
          }
        }
      ]
    },
    "false_claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "reason"],
      "properties": {
        "value": {"const": false},
        "reason": {
          "enum": [
            "no_live_render_evidence",
            "no_export_json_supplied",
            "no_playwright_visual_regression_run",
            "accessibility_gate_not_executed_on_real_dom",
            "release_gate_evidence_missing"
          ]
        }
      }
    }
  }
}
