{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive.local/schemas/ev4-responsive-pilot-run-record.schema.json",
  "title": "EV4 Responsive Pilot Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run_id",
    "run_mode",
    "section_id",
    "source_packet_id",
    "source_readiness_id",
    "readiness_status",
    "authorization_scope",
    "dry_run_only",
    "stage_sequence_verified",
    "generated_artifacts",
    "carry_forward_flags",
    "blocked_actions",
    "forbidden_claims",
    "validation_boundary",
    "next_allowed_action"
  ],
  "properties": {
    "schema": {"const": "ev4-responsive-pilot-run-record@1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "run_mode": {"enum": ["sample_submitted_packet_dry_run", "submitted_packet_shadow_mode"]},
    "section_id": {"type": "string", "minLength": 1},
    "source_packet_id": {"type": "string", "minLength": 1},
    "source_readiness_id": {"type": "string", "minLength": 1},
    "readiness_status": {"enum": ["ready_for_shadow_mode_pilot", "partial_ready_with_visible_flags"]},
    "authorization_scope": {"enum": ["shadow_mode_only", "shadow_mode_only_with_visible_flags"]},
    "dry_run_only": {"type": "boolean"},
    "stage_sequence_verified": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pilot_manifest_checked", "required_sequence_complete", "execution_templates_present"],
      "properties": {
        "pilot_manifest_checked": {"const": true},
        "required_sequence_complete": {"const": true},
        "execution_templates_present": {"const": true}
      }
    },
    "generated_artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "carry_forward_flags": {
      "type": "array",
      "items": {"$ref": "#/$defs/visible_flag"}
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 5,
      "items": {
        "enum": [
          "production_ready",
          "release_ready",
          "live_render_validated",
          "export_json_validated",
          "accessibility_passed",
          "playwright_visual_regression_validated"
        ]
      }
    },
    "validation_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_elementor_render_validated",
        "export_json_validated",
        "playwright_visual_regression_validated",
        "accessibility_pass_claimed",
        "production_ready_claimed"
      ],
      "properties": {
        "live_elementor_render_validated": {"$ref": "#/$defs/false_boundary"},
        "export_json_validated": {"$ref": "#/$defs/false_boundary"},
        "playwright_visual_regression_validated": {"$ref": "#/$defs/false_boundary"},
        "accessibility_pass_claimed": {"$ref": "#/$defs/false_boundary"},
        "production_ready_claimed": {"$ref": "#/$defs/false_boundary"}
      }
    },
    "next_allowed_action": {"enum": ["collect_real_evidence", "start_shadow_mode_pilot_with_current_packet"]}
  },
  "allOf": [
    {
      "if": {"properties": {"dry_run_only": {"const": true}}},
      "then": {
        "properties": {
          "run_mode": {"const": "sample_submitted_packet_dry_run"},
          "next_allowed_action": {"const": "collect_real_evidence"}
        }
      }
    },
    {
      "if": {"properties": {"dry_run_only": {"const": false}}},
      "then": {
        "properties": {
          "run_mode": {"const": "submitted_packet_shadow_mode"},
          "next_allowed_action": {"const": "start_shadow_mode_pilot_with_current_packet"}
        }
      }
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_path", "artifact_type", "status"],
      "properties": {
        "artifact_path": {"type": "string", "minLength": 1},
        "artifact_type": {"enum": ["readiness_report", "run_record", "template_reference"]},
        "status": {"enum": ["generated", "referenced"]}
      }
    },
    "visible_flag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag_code", "severity", "source_ref", "required_handling"],
      "properties": {
        "flag_code": {
          "enum": [
            "breakpoint_source_not_export_verified",
            "visual_only_evidence",
            "no_live_render_evidence",
            "no_export_json_evidence",
            "accessibility_not_validated"
          ]
        },
        "severity": {"enum": ["medium", "minor", "note"]},
        "source_ref": {"type": "string", "minLength": 1},
        "required_handling": {"type": "string", "minLength": 1}
      }
    },
    "false_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "reason"],
      "properties": {
        "value": {"const": false},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
