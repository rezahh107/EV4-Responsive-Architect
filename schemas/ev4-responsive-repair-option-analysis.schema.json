{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-repair-option-analysis.schema.json",
  "title": "EV4 Responsive Repair Option Analysis",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.:/@-]+$" },
    "stringArray": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "yesNoUnknown": { "enum": ["yes", "no", "unknown"] },
    "risk": { "enum": ["low", "medium", "high", "unknown"] },
    "evidenceLabel": { "enum": ["SUPPORTED_EVIDENCE", "PARTIALLY_SUPPORTED_EVIDENCE", "INFERRED_EVIDENCE", "ABSENT_EVIDENCE", "CONTRADICTED_EVIDENCE", "UNRESOLVED_CONFLICT", "NON_APPLICABLE"] },
    "repairType": { "enum": ["elementor_native_control", "design_system_variable", "scoped_css", "decoration_hide_or_simplify", "asset_media_adjustment", "build_tree_route", "evidence_request"] },
    "owner": { "enum": ["responsive_repair", "implementation_repair", "build_tree_repair", "main_pipeline_rerun", "evidence_request", "accessibility_review"] }
  },
  "required": ["schema", "analysis_id", "failure_options"],
  "properties": {
    "schema": { "const": "ev4-responsive-repair-option-analysis@1.0.0" },
    "analysis_id": { "$ref": "#/$defs/id" },
    "failure_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["failure_id", "options"],
        "properties": {
          "failure_id": { "$ref": "#/$defs/id" },
          "options": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "option_id",
                "repair_owner",
                "repair_type",
                "native_control_possible",
                "scoped_css_needed",
                "desktop_regression_risk",
                "cascade_risk",
                "accessibility_risk",
                "evidence_support",
                "selection_status",
                "rejected_reason_if_not_selected",
                "verification_required"
              ],
              "properties": {
                "option_id": { "$ref": "#/$defs/id" },
                "repair_owner": { "$ref": "#/$defs/owner" },
                "repair_type": { "$ref": "#/$defs/repairType" },
                "native_control_possible": { "$ref": "#/$defs/yesNoUnknown" },
                "scoped_css_needed": { "$ref": "#/$defs/yesNoUnknown" },
                "desktop_regression_risk": { "$ref": "#/$defs/risk" },
                "cascade_risk": { "$ref": "#/$defs/risk" },
                "accessibility_risk": { "$ref": "#/$defs/risk" },
                "evidence_support": { "$ref": "#/$defs/evidenceLabel" },
                "selection_status": { "enum": ["candidate", "selected", "rejected", "deferred", "blocked"] },
                "rejected_reason_if_not_selected": { "type": ["string", "null"] },
                "verification_required": { "$ref": "#/$defs/stringArray" }
              }
            }
          }
        }
      }
    }
  }
}
