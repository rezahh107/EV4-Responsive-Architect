{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-responsive-rolling-queue@1.0.0",
  "title": "EV4 Responsive Rolling Queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "queue_id",
    "project",
    "queue_status",
    "controller_policy",
    "active_cycle",
    "tasks",
    "forbidden_claims"
  ],
  "properties": {
    "schema": { "const": "ev4-responsive-rolling-queue@1.0.0" },
    "queue_id": { "type": "string", "pattern": "^EV4RQ-[0-9]{4}-[A-Z0-9-]+$" },
    "project": { "const": "EV4 Responsive Architect" },
    "queue_status": {
      "type": "string",
      "enum": ["active", "paused", "blocked_waiting_for_real_evidence", "complete"]
    },
    "controller_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_task_per_run",
        "critique_same_task",
        "small_in_scope_fixes_allowed",
        "ci_required_for_repo_changes",
        "minimum_pending_tasks",
        "refresh_every_nth_task",
        "real_pilot_requires_submitted_packet_and_readiness_pass"
      ],
      "properties": {
        "one_task_per_run": { "const": true },
        "critique_same_task": { "const": true },
        "small_in_scope_fixes_allowed": { "const": true },
        "ci_required_for_repo_changes": { "const": true },
        "minimum_pending_tasks": { "const": 4 },
        "refresh_every_nth_task": { "const": 5 },
        "real_pilot_requires_submitted_packet_and_readiness_pass": { "const": true }
      }
    },
    "active_cycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cycle_id", "cycle_status", "started_from_status", "goal", "task_order"],
      "properties": {
        "cycle_id": { "type": "string", "pattern": "^CYCLE-[0-9]{3}$" },
        "cycle_status": { "type": "string", "enum": ["planned", "active", "complete", "blocked"] },
        "started_from_status": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "task_order": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/task" }
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "production_ready",
          "release_ready",
          "pixel_perfect",
          "live_render_validated",
          "export_json_validated",
          "accessibility_passed",
          "sample_packet_used_as_real_evidence",
          "numeric_score_overrides_gate"
        ]
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "cycle_position",
        "task_type",
        "status",
        "title",
        "objective",
        "allowed_work",
        "forbidden_work",
        "requires_real_evidence",
        "expected_artifacts",
        "acceptance_criteria",
        "critique_required",
        "dependencies"
      ],
      "properties": {
        "task_id": { "type": "string", "pattern": "^RQ-[0-9]{4}$" },
        "cycle_position": { "type": "integer", "minimum": 1, "maximum": 5 },
        "task_type": {
          "type": "string",
          "enum": ["repo_sync", "evidence_bridge", "validator_hardening", "pilot_preparation", "real_evidence_execution", "queue_refresh"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "merged", "blocked", "skipped", "superseded"]
        },
        "title": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "allowed_work": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "forbidden_work": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "requires_real_evidence": { "type": "boolean" },
        "expected_artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "critique_required": { "const": true },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "blocker_reason": { "type": "string" },
        "completed_pr": { "type": "integer", "minimum": 1 },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "blocked" } }, "required": ["status"] },
          "then": { "required": ["blocker_reason"] }
        },
        {
          "if": { "properties": { "cycle_position": { "const": 5 } }, "required": ["cycle_position"] },
          "then": { "properties": { "task_type": { "const": "queue_refresh" } } }
        }
      ]
    }
  }
}
