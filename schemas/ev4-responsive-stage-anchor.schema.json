{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ev4-responsive-stage-anchor.schema.json",
  "title": "EV4 Responsive Stage Anchor",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "schemaVersion": { "type": "string", "pattern": "^ev4-[A-Za-z0-9_.-]+@\\d+\\.\\d+\\.\\d+$" }
  },
  "required": [
    "schema",
    "source_stage",
    "target_stage",
    "target_stage_hardening_status",
    "project_status_version",
    "payload_schema_in",
    "payload_schema_out",
    "critical_unknowns",
    "confidence_delta",
    "blocking_items",
    "gate_results",
    "audit_flags",
    "required_user_confirmations",
    "partial_rerun_state",
    "allowed_work",
    "forbidden_work",
    "stop_conditions",
    "debug_trace_required"
  ],
  "properties": {
    "schema": { "const": "ev4-responsive-stage-anchor@1.0.0" },
    "source_stage": { "$ref": "#/$defs/nonEmptyString" },
    "target_stage": { "$ref": "#/$defs/nonEmptyString" },
    "target_stage_hardening_status": { "enum": ["draft", "stub", "hardening_candidate", "hardened_v0_1", "blocked"] },
    "project_status_version": { "$ref": "#/$defs/nonEmptyString" },
    "payload_schema_in": { "type": "array", "items": { "$ref": "#/$defs/schemaVersion" }, "uniqueItems": true },
    "payload_schema_out": { "type": "array", "items": { "$ref": "#/$defs/schemaVersion" }, "uniqueItems": true },
    "critical_unknowns": { "$ref": "#/$defs/stringArray" },
    "confidence_delta": { "enum": ["increased", "decreased", "unchanged", "not_assessed"] },
    "blocking_items": { "$ref": "#/$defs/stringArray" },
    "gate_results": { "type": "object", "additionalProperties": { "enum": ["pass", "fail", "not_applicable", "blocked", "warning"] } },
    "audit_flags": { "$ref": "#/$defs/stringArray" },
    "required_user_confirmations": { "$ref": "#/$defs/stringArray" },
    "partial_rerun_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reusable_payloads", "invalidated_payloads"],
      "properties": {
        "status": { "enum": ["none", "active", "required", "blocked"] },
        "reusable_payloads": { "$ref": "#/$defs/stringArray" },
        "invalidated_payloads": { "$ref": "#/$defs/stringArray" }
      }
    },
    "allowed_work": { "$ref": "#/$defs/stringArray" },
    "forbidden_work": { "$ref": "#/$defs/stringArray" },
    "stop_conditions": { "$ref": "#/$defs/stringArray" },
    "debug_trace_required": { "type": "boolean" }
  }
}
