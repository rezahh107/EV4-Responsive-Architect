{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-responsive-task-quality-review.schema.json",
  "title": "EV4 Responsive Task Quality Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "review_id",
    "task_ref",
    "task_type",
    "task_sensitivity",
    "deterministic_checks",
    "self_critique",
    "cross_critique",
    "findings",
    "boundary_assertions",
    "final_verdict",
    "completion_allowed"
  ],
  "properties": {
    "schema": {"const": "ev4-responsive-task-quality-review@1.0.0"},
    "review_id": {"type": "string", "pattern": "^TQR-[0-9]{4,}$"},
    "task_ref": {"type": "string", "pattern": "^RQ-[0-9]{4}$"},
    "task_type": {
      "enum": [
        "documentation_sync",
        "schema_hardening",
        "automation_control",
        "readiness_gate",
        "sample_vs_real_safety",
        "risk_priority_engine",
        "evidence_boundary",
        "production_boundary",
        "ci_workflow",
        "repo_maintenance"
      ]
    },
    "task_sensitivity": {"enum": ["normal", "sensitive", "critical"]},
    "deterministic_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptance_criteria_checked",
        "scope_respected",
        "forbidden_work_absent",
        "ci_checked_or_no_ci_reason_recorded",
        "artifacts_listed",
        "queue_state_checked",
        "ledger_state_checked",
        "stale_reference_search_done",
        "delayed_bot_review_window_checked",
        "boundary_assertions_checked"
      ],
      "properties": {
        "acceptance_criteria_checked": {"type": "boolean"},
        "scope_respected": {"type": "boolean"},
        "forbidden_work_absent": {"type": "boolean"},
        "ci_checked_or_no_ci_reason_recorded": {"type": "boolean"},
        "artifacts_listed": {"type": "boolean"},
        "queue_state_checked": {"type": "boolean"},
        "ledger_state_checked": {"type": "boolean"},
        "stale_reference_search_done": {"type": "boolean"},
        "delayed_bot_review_window_checked": {"type": "boolean"},
        "boundary_assertions_checked": {"type": "boolean"}
      }
    },
    "self_critique": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recorded", "summary"],
      "properties": {
        "recorded": {"type": "boolean"},
        "summary": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}}
      }
    },
    "cross_critique": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status", "reviewer_role", "prompt_separation", "temperature_policy"],
      "properties": {
        "required": {"type": "boolean"},
        "status": {"enum": ["not_required", "completed", "blocked_missing_cross_critique"]},
        "reviewer_role": {"enum": ["strict_pessimistic_reviewer", "not_required"]},
        "prompt_separation": {"type": "boolean"},
        "temperature_policy": {"enum": ["temperature_0_1_recommended", "deterministic_external_step_required", "not_required"]}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "description", "in_scope", "fixed", "follow_up_task_required"],
        "properties": {
          "severity": {"enum": ["P0", "P1", "P2", "P3", "note"]},
          "code": {"type": "string", "pattern": "^TQ_[A-Z0-9_]+$"},
          "description": {"type": "string", "minLength": 5},
          "in_scope": {"type": "boolean"},
          "fixed": {"type": "boolean"},
          "follow_up_task_required": {"type": "boolean"}
        }
      }
    },
    "boundary_assertions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": [
          "no_self_critique_only_completion",
          "deterministic_checks_passed",
          "cross_critique_completed_when_required",
          "bot_review_window_checked",
          "no_production_claim",
          "no_release_claim",
          "no_unrelated_task",
          "follow_up_created_when_required"
        ]
      },
      "uniqueItems": true
    },
    "final_verdict": {"enum": ["pass", "needs_follow_up", "blocked"]},
    "completion_allowed": {"type": "boolean"}
  }
}
