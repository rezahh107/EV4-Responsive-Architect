{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-responsive-architect.local/schemas/ev4-viewport-inheritance-reset-matrix.schema.json",
  "title": "EV4 Viewport Inheritance and Reset Decision Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "viewport_decisions",
    "boundary_assertions"
  ],
  "properties": {
    "viewport_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_ref",
          "viewport",
          "property_path",
          "decision",
          "source_viewport",
          "source_ref",
          "reason",
          "conflicts"
        ],
        "properties": {
          "node_ref": {"type": "string", "minLength": 1},
          "viewport": {"enum": ["desktop", "tablet", "mobile"]},
          "property_path": {"type": "string", "minLength": 1},
          "decision": {"enum": ["explicit", "inherited", "reset", "inactive", "unknown"]},
          "source_viewport": {
            "type": ["string", "null"],
            "enum": ["desktop", "tablet", "mobile", null]
          },
          "source_ref": {"type": ["string", "null"]},
          "reason": {"type": "string", "minLength": 1},
          "conflicts": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "boundary_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_evidence_created",
        "issue_8_mutated",
        "pilot_executed_or_authorized",
        "production_ready",
        "release_ready",
        "live_render_validated",
        "export_json_validated",
        "accessibility_passed",
        "pixel_perfect",
        "responsive_correctness_validated",
        "ci_success_treated_as_responsive_correctness_evidence"
      ],
      "properties": {
        "submitted_evidence_created": {"const": false},
        "issue_8_mutated": {"const": false},
        "pilot_executed_or_authorized": {"const": false},
        "production_ready": {"const": false},
        "release_ready": {"const": false},
        "live_render_validated": {"const": false},
        "export_json_validated": {"const": false},
        "accessibility_passed": {"const": false},
        "pixel_perfect": {"const": false},
        "responsive_correctness_validated": {"const": false},
        "ci_success_treated_as_responsive_correctness_evidence": {"const": false}
      }
    }
  }
}
